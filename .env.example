# Local development environment variables
# Copy this file to .env and fill in values — never commit .env

# ---- AWS region & secret ARNs ----
# These are resolved at startup to pull all other config from Secrets Manager
AWS_REGION=us-east-1
AWS_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:my-app-secrets
AWS_DB_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:my-db-secrets

# ---- Expected shape of the app secret JSON (AWS_SECRET_ARN) ----
# {
#   "NODE_ENV": "local",
#   "PORT": "8000",
#   "DB_NAME": "mydb",
#   "DB_HOST": "localhost",
#   "DB_PROXY_URL": "",
#   "API_KEY_HASH": "<bcrypt hash of your API key>"
# }

# ---- Expected shape of the DB secret JSON (AWS_DB_SECRET_ARN) ----
# {
#   "username": "postgres",
#   "password": "postgres"
# }
